{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://anubias.app"
        },
        {
          "url": "custom:*"
        }
      ]
    },
    "dialog:default",
    "fs:default"
  ]
}